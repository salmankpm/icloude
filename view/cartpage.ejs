<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>I CLOUDS | Your Cart</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        :root {
            --primary-red: #ff4d4d;
            --text-dark: #222;
            --text-muted: #888;
            --bg-light: #f9f9f9;
            --border-color: #ebebeb;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: #fff;
            color: var(--text-dark);
        }

        /* TOP NAVIGATION */
        .top-nav {
            border-bottom: 1px solid var(--border-color);
            padding: 15px 0;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 24px;
            letter-spacing: 1px;
        }

        .nav-link {
            font-size: 14px;
            font-weight: 500;
            color: var(--text-dark) !important;
            margin: 0 10px;
        }

        /* BREADCRUMB */
        .breadcrumb-section {
            background: var(--bg-light);
            padding: 20px 0;
            margin-bottom: 40px;
            font-size: 13px;
            color: var(--text-muted);
        }

        /* CART LAYOUT */
        .cart-title {
            font-weight: 700;
            font-size: 28px;
            margin-bottom: 30px;
        }

        .cart-table thead {
            border-bottom: 2px solid var(--text-dark);
        }

        .cart-table th {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding-bottom: 15px;
            color: var(--text-muted);
        }

        .cart-item-row {
            border-bottom: 1px solid var(--border-color);
        }

        .product-img-box {
            background: var(--bg-light);
            padding: 15px;
            border-radius: 8px;
            width: 100px;
            height: 100px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .product-img-box img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

        .item-info h5 {
            font-size: 16px;
            font-weight: 600;
            margin: 0;
        }

        .item-info span {
            font-size: 12px;
            color: var(--text-muted);
        }

        .price-text {
            font-weight: 600;
            font-size: 16px;
        }

        /* ACTION BUTTONS */
        .btn-action {
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            padding: 8px 16px;
            border-radius: 50px;
            transition: 0.3s;
            text-decoration: none;
            display: inline-block;
        }

        .btn-buy {
            background: var(--text-dark);
            color: #fff;
            border: 1px solid var(--text-dark);
        }

        .btn-buy:hover {
            background: var(--primary-red);
            border-color: var(--primary-red);
            color: #fff;
        }

        .btn-remove {
            color: var(--text-muted);
            margin-left: 10px;
        }

        .btn-remove:hover {
            color: var(--primary-red);
        }

        /* SUMMARY SIDEBAR */
        .summary-card {
            background: var(--bg-light);
            border-radius: 12px;
            padding: 30px;
            position: sticky;
            top: 20px;
        }

        .summary-card h4 {
            font-weight: 700;
            font-size: 18px;
            margin-bottom: 20px;
        }

        .summary-line {
            display: flex;
            justify-content: space-between;
            margin-bottom: 12px;
            font-size: 14px;
        }

        .summary-total {
            border-top: 1px solid var(--border-color);
            padding-top: 15px;
            margin-top: 15px;
            font-weight: 700;
            font-size: 18px;
        }

        .btn-checkout {
            width: 100%;
            background: var(--text-dark);
            color: #fff;
            padding: 15px;
            border-radius: 8px;
            text-transform: uppercase;
            font-weight: 600;
            letter-spacing: 1px;
            margin-top: 20px;
            border: none;
            transition: 0.3s;
        }

        .btn-checkout:hover {
            background: var(--primary-red);
        }
    </style>
</head>

<body>

    <!-- NAVIGATION -->
    <nav class="navbar navbar-expand-lg top-nav">
        <div class="container">
            <a class="navbar-brand text-black" href="/index">I CLOUDS</a>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    
                </ul>
                <div class="d-flex align-items-center">
                    <a href="/logout" class="btn btn-outline-dark btn-sm px-4 rounded-pill">Logout</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- BREADCRUMB -->
    <div class="breadcrumb-section">
        <div class="container">
            <span>Home / Shopping Cart</span>
        </div>
    </div>

    <div class="container mb-5">
        <h2 class="cart-title">Your Shopping Bag</h2>

        <div class="row g-5">
            <!-- Left Side: Items -->
            <div class="col-lg-8">
                <div class="table-responsive">
                    <table class="table cart-table align-middle">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Category</th>
                                <th>Price</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% let subtotal = 0; 
                               for(let i = 0; i < prodectDetails.length; i++){ 
                               if(!prodectDetails[i]) continue;
                               subtotal += Number(prodectDetails[i].price); %>
                            
                            <tr class="cart-item-row">
                                <td class="py-4">
                                    <div class="d-flex align-items-center">
                                        <div class="product-img-box shadow-sm">
                                            <img src="/image/<%= prodectDetails[i].image %>" alt="">
                                        </div>
                                        <div class="item-info ms-3">
                                            <h5><%= prodectDetails[i].name %></h5>
                                            <span>SKU: CLD-00<%= i+1 %></span>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-muted"><%= prodectDetails[i].category %></td>
                                <td class="price-text">₹ <%= prodectDetails[i].price %></td>
                                <td class="text-end">
                                    <a href="/placeorder?prodectId=<%= prodectDetails[i]._id %>" class="btn-action btn-buy">Buy</a>
                                    <a href="/deletecart?prodectId=<%= prodectDetails[i]._id %>" class="btn-action btn-remove">✕</a>
                                </td>
                            </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
                
                <a href="/index" class="btn btn-link text-dark text-decoration-none mt-3 p-0">
                    ← Continue Shopping
                </a>
            </div>

            <!-- Right Side: Summary -->
            <div class="col-lg-4">
                <div class="summary-card shadow-sm">
                    <h4>Order Summary</h4>
                    
                    <div class="summary-line">
                        <span>Subtotal (<%= prodectDetails.length %> items)</span>
                        <span>₹ <%= subtotal %></span>
                    </div>
                    <div class="summary-line">
                        <span>Shipping</span>
                        <span class="text-success">FREE</span>
                    </div>
                    <div class="summary-line">
                        <span>Estimated Tax</span>
                        <span>₹ 0.00</span>
                    </div>

                    <div class="summary-line summary-total">
                        <span>Total</span>
                        <span>₹ <%= subtotal %></span>
                    </div>

                    <button class="btn-checkout shadow">Checkout Now</button>
                    
                    <div class="mt-4 text-center">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/b/b5/PayPal.svg/1200px-PayPal.svg.png" height="20" class="mx-2 opacity-50" alt="">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/5/5e/Visa_Inc._logo.svg/2560px-Visa_Inc._logo.svg.png" height="15" class="mx-2 opacity-50" alt="">
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>