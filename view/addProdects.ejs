<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>I Clouds | Add Product</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        :root {
            --primary-red: #ff4d4d;
            --text-dark: #222;
            --text-muted: #888;
            --bg-light: #f9f9f9;
            --border-color: #ebebeb;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: #fff;
            color: var(--text-dark);
        }

        /* TOP NAVIGATION (Same as Dashboard) */
        .top-nav {
            border-bottom: 1px solid var(--border-color);
            padding: 15px 0;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 24px;
            letter-spacing: 1px;
        }

        .nav-link {
            font-size: 14px;
            font-weight: 500;
            color: var(--text-dark) !important;
            margin: 0 10px;
        }

        /* BREADCRUMB */
        .breadcrumb-section {
            background: var(--bg-light);
            padding: 20px 0;
            margin-bottom: 40px;
            font-size: 13px;
            color: var(--text-muted);
        }

        /* FORM STYLING */
        .form-container {
            max-width: 600px;
            margin: 0 auto 100px;
            padding: 40px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
        }

        .form-title {
            font-size: 22px;
            font-weight: 600;
            margin-bottom: 30px;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        label {
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 8px;
            display: block;
            text-transform: uppercase;
            color: var(--text-dark);
        }

        .form-control, .form-select {
            border-radius: 4px;
            padding: 12px;
            border: 1px solid var(--border-color);
            font-size: 14px;
            margin-bottom: 20px;
            background-color: var(--bg-light);
        }

        .form-control:focus, .form-select:focus {
            box-shadow: none;
            border-color: var(--text-dark);
            background-color: #fff;
        }

        .btn-submit {
            background: var(--text-dark);
            color: #fff;
            border: none;
            padding: 15px;
            width: 100%;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: 0.3s;
            margin-top: 10px;
        }

        .btn-submit:hover {
            background: var(--primary-red);
            color: #fff;
        }

        .file-input-label {
            display: block;
            border: 2px dashed var(--border-color);
            padding: 30px;
            text-align: center;
            cursor: pointer;
            color: var(--text-muted);
            margin-bottom: 20px;
            transition: 0.3s;
        }

        .file-input-label:hover {
            border-color: var(--primary-red);
            color: var(--primary-red);
        }
    </style>
</head>

<body>

    <!-- TOP NAVIGATION -->
    <nav class="navbar navbar-expand-lg top-nav">
        <div class="container">
            <a class="navbar-brand text-black" href="/index">I CLOUDS</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link" href="/dashboard">Dashboard</a></li>
                    
                    <li class="nav-item"><a class="nav-link" href="/blockedusers">Users</a></li>
                    <li class="nav-item"><a class="nav-link" href="/restoreProdect">Archives</a></li>
                </ul>
                <div class="d-flex align-items-center">
                    <a href="/logoutuser" class="btn btn-outline-dark btn-sm rounded-pill px-4 mt-2 mt-lg-0">Logout</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- BREADCRUMB -->
    <div class="breadcrumb-section">
        <div class="container">
            <span>Home / Admin / Add New Product</span>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="container">
        <div class="form-container">
            <h2 class="form-title">Product Details</h2>

            <form action="/addProdect" method="POST" enctype="multipart/form-data">
                
                <label for="name">Product Name</label>
                <input type="text" id="name" name="name" class="form-control" placeholder="e.g. iPhone 15 Pro" required>

                <label for="price">Price (₹)</label>
                <input type="number" id="price" name="price" class="form-control" placeholder="e.g. 79900" required>

                <label for="category">Category</label>
                <select id="category" name="category" class="form-select" required>
                    <option value="" disabled selected>Choose a category...</option>
                    <% for(let i=0; i < categories.length; i++){ %>
                        <option value="<%= categories[i].name %>">
                            <%= categories[i].name %>
                        </option>
                    <% } %>
                </select>

                <label>Product Image</label>
                <label for="image" class="file-input-label">
                    <span id="file-name">Click to upload product image</span>
                    <input type="file" id="image" name="image" class="d-none" required onchange="updateFileName(this)">
                </label>

                <button type="submit" class="btn-submit">Upload Product</button>
            </form>
        </div>
    </div>

    <script>
        // Visual helper to show the selected file name
        function updateFileName(input) {
            const fileName = input.files[0].name;
            document.getElementById('file-name').textContent = "Selected: " + fileName;
            document.getElementById('file-name').style.color = "var(--primary-red)";
        }
    </script>

</body>

</html>