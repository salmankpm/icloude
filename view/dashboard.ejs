<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>I Clouds | Admin Dashboard</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        :root {
            --primary-red: #ff4d4d;
            --text-dark: #222;
            --text-muted: #888;
            --bg-light: #f9f9f9;
            --border-color: #ebebeb;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: #fff;
            color: var(--text-dark);
        }

        /* TOP NAVIGATION */
        .top-nav {
            border-bottom: 1px solid var(--border-color);
            padding: 15px 0;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 24px;
            letter-spacing: 1px;
        }

        .nav-link {
            font-size: 14px;
            font-weight: 500;
            color: var(--text-dark) !important;
            margin: 0 10px;
        }
        .nav-link.active {
        font-weight: 700 !important;
        color: #000 !important;
        border-bottom: 2px solid #ff4d4d; /* Matches your red theme accent */
    }

        /* BREADCRUMB */
        .breadcrumb-section {
            background: var(--bg-light);
            padding: 20px 0;
            margin-bottom: 40px;
            font-size: 13px;
            color: var(--text-muted);
        }

        /* SIDEBAR FILTERS & ACTIONS */
        .filter-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid #000;
            display: inline-block;
        }

        .filter-list {
            list-style: none;
            padding: 0;
            margin-bottom: 30px;
        }

        .filter-list li {
            padding: 8px 0;
            font-size: 14px;
            color: var(--text-muted);
            display: flex;
            justify-content: space-between;
        }

        /* PRODUCT CARDS */
        .product-card {
            border: none;
            margin-bottom: 40px;
            text-align: center;
            transition: transform 0.3s ease;
        }

        .img-container {
            background-color: var(--bg-light);
            border-radius: 8px;
            padding: 30px;
            margin-bottom: 15px;
            position: relative;
        }

        .product-card img {
            max-width: 100%;
            height: 200px;
            object-fit: contain;
        }

        .product-name {
            font-size: 15px;
            font-weight: 500;
            margin-bottom: 8px;
            color: var(--text-dark);
            text-decoration: none;
            display: block;
        }

        .product-price {
            font-weight: 600;
            font-size: 16px;
            color: var(--primary-red);
        }

        /* ADMIN TOOLS */
        .admin-tools {
            margin-top: 10px;
            display: flex;
            justify-content: center;
            gap: 10px;
        }

        .btn-action {
            font-size: 11px;
            text-transform: uppercase;
            font-weight: 600;
            padding: 6px 15px;
            border-radius: 4px;
        }
    </style>
</head>

<body>

    <!-- TOP NAVIGATION -->
    <nav class="navbar navbar-expand-lg top-nav">
        <div class="container">
            <a class="navbar-brand text-black" href="/index">I CLOUDS</a>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                     <li class="nav-item"><a class="nav-link" href="/index">Home</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/dashboard">Dashboard</a></li>
                   
                    <li class="nav-item"><a class="nav-link" href="/blockedusers">Users</a></li>
                    <li class="nav-item"><a class="nav-link" href="/restoreProdect">Archives</a></li>
                </ul>
                <a href="#" class="btn btn-dark btn-sm px-4 rounded-pill">Logout</a>
            </div>
        </div>
    </nav>
   
    <!-- BREADCRUMB -->
    <div class="breadcrumb-section">
        <div class="container text-center text-md-start">
            <span>Home / Admin / Products</span>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="container">
        <div class="row">
            
            <!-- LEFT SIDEBAR -->
            <div class="col-lg-3">
                <!-- MANAGEMENT SECTION -->
                <div class="mb-5">
                    <h5 class="filter-title">Management</h5>
                    <div class="d-grid gap-2">
                        <!-- THE ADD CATEGORY BUTTON IS HERE -->
                        <button class="btn btn-dark py-2 fw-bold" data-bs-toggle="modal" data-bs-target="#categoryModal">
                            + ADD CATEGORY
                        </button>
                        <a href="/addProdect" class="btn btn-outline-dark py-2 fw-bold">
                            + ADD PRODUCT
                        </a>
                    </div>
                </div>

                <!-- STATS SECTION -->
                <div class="mb-5">
                    <h5 class="filter-title">Dashboard Stats</h5>
                    <ul class="filter-list">
                        <li>Total Users <span><%= totalUsers %></span></li>
                        <li>Total Products <span><%= prodectCount %></span></li>
                        <li>Revenue <span>₹2,450</span></li>
                    </ul>
                </div>
            </div>

            <!-- PRODUCT GRID -->
            <div class="col-lg-9">
                <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                    <p class="text-muted mb-0 small">Displaying <%= prodects.length %> Products</p>
                    <select class="form-select form-select-sm border-0 bg-light w-auto">
                        <option>Sort By: Default</option>
                        <option>Price: Low to High</option>
                    </select>
                </div>

                <div class="row">
                    <% for(let i=0; i < prodects.length; i++) { %>
                        <div class="col-md-4 col-sm-6">
                            <div class="product-card">
                                <div class="img-container">
                                    <img src="/image/<%= prodects[i].image %>" alt="Product Image">
                                </div>
                                <div class="text-warning small mb-1">★★★★★</div>
                                <span class="product-name"><%= prodects[i].name %></span>
                                <div class="product-price">₹<%= prodects[i].price %></div>

                                <div class="admin-tools">
                                    <button class="btn btn-outline-dark btn-action" onclick="window.location='/getedit?prodectId=<%=prodects[i]._id%>'">
                                        Edit
                                    </button>
                                    <button class="btn btn-danger btn-action" onclick="openDeleteModal('<%=prodects[i]._id%>')">
                                        Delete
                                    </button>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- ADD CATEGORY MODAL -->
    <div class="modal fade" id="categoryModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">Manage Categories</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <form action="/addCategory" method="POST" class="mb-4">
                        <label class="form-label small fw-bold">New Category Name</label>
                        <div class="input-group">
                            <input type="text" name="category" class="form-control" placeholder="e.g. Smartwatch" required>
                            <button class="btn btn-success">Add</button>
                        </div>
                    </form>
                    
                    <h6 class="border-bottom pb-2 mb-3 small fw-bold text-uppercase">Existing Categories</h6>
                    <div class="list-group list-group-flush">
                        <% for(let i=0; i < categories.length; i++) { %>
                            <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span class="text-capitalize"><%= categories[i].name %></span>
                                <a href="/deleteCategory?id=<%= categories[i]._id %>" class="btn btn-sm btn-outline-danger border-0">Delete</a>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- DELETE PRODUCT MODAL -->
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content text-center p-4">
                <h5 class="fw-bold">Confirm Delete</h5>
                <p class="text-muted small">Are you sure you want to remove this product?</p>
                <div class="d-flex gap-2 justify-content-center mt-3">
                    <button type="button" class="btn btn-light btn-sm px-4" data-bs-dismiss="modal">Cancel</button>
                    <a id="confirmDeleteBtn" href="#" class="btn btn-danger btn-sm px-4">Yes, Delete</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        function openDeleteModal(id) {
            const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
            document.getElementById("confirmDeleteBtn").href = "/deleteProduct?prodectId=" + id;
            deleteModal.show();
        }
    </script>

</body>
</html>