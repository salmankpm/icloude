<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>I Clouds | Edit Product</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        :root {
            --primary-red: #ff4d4d;
            --text-dark: #222;
            --text-muted: #888;
            --bg-light: #f9f9f9;
            --border-color: #ebebeb;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: #fff;
            color: var(--text-dark);
        }

        /* TOP NAVIGATION */
        .top-nav {
            border-bottom: 1px solid var(--border-color);
            padding: 15px 0;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 24px;
            letter-spacing: 1px;
        }

        .nav-link {
            font-size: 14px;
            font-weight: 500;
            color: var(--text-dark) !important;
            margin: 0 10px;
        }

        /* BREADCRUMB */
        .breadcrumb-section {
            background: var(--bg-light);
            padding: 20px 0;
            margin-bottom: 40px;
            font-size: 13px;
            color: var(--text-muted);
        }

        /* FORM STYLING */
        .form-container {
            max-width: 800px;
            margin: 0 auto 100px;
            padding: 40px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
        }

        .form-title {
            font-size: 22px;
            font-weight: 600;
            margin-bottom: 30px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        label {
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 8px;
            display: block;
            text-transform: uppercase;
            color: var(--text-dark);
        }

        .form-control, .form-select {
            border-radius: 4px;
            padding: 12px;
            border: 1px solid var(--border-color);
            font-size: 14px;
            margin-bottom: 20px;
            background-color: var(--bg-light);
        }

        .form-control:focus {
            box-shadow: none;
            border-color: var(--text-dark);
            background-color: #fff;
        }

        /* IMAGE PREVIEW AREA */
        .current-image-box {
            background: var(--bg-light);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 20px;
            text-align: center;
        }

        .current-image-box img {
            max-width: 100%;
            height: 200px;
            object-fit: contain;
            border-radius: 4px;
        }

        .btn-update {
            background: var(--text-dark);
            color: #fff;
            border: none;
            padding: 15px;
            width: 100%;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: 0.3s;
        }

        .btn-update:hover {
            background: var(--primary-red);
            color: #fff;
        }
    </style>
</head>

<body>

    <!-- TOP NAVIGATION -->
    <nav class="navbar navbar-expand-lg top-nav">
        <div class="container">
            <a class="navbar-brand text-black" href="/index">I CLOUDS</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link" href="/dashboard">Dashboard</a></li>
                   
                    <li class="nav-item"><a class="nav-link" href="/admin/users">Users</a></li>
                    <li class="nav-item"><a class="nav-link" href="/restoreProdect">Archives</a></li>
                </ul>
                <div class="d-flex align-items-center">
                    <a href="/logout" class="btn btn-outline-dark btn-sm rounded-pill px-4">Logout</a>
                </div>
            </div>
        </div>
    </nav>
    

    <!-- BREADCRUMB -->
    <div class="breadcrumb-section">
        <div class="container">
            <span>Home / Admin / Edit / <%= prodectDetails.name %></span>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="container">
        <div class="form-container">
            <h2 class="form-title">Update Product</h2>

            <form action="/postedit?prodectId=<%= prodectDetails._id %>" method="POST" enctype="multipart/form-data">
                <div class="row">
                    <!-- Form Fields -->
                    <div class="col-md-7">
                        <label for="name">Product Name</label>
                        <input type="text" id="name" name="name" class="form-control" value="<%= prodectDetails.name %>" required>

                        <label for="price">Price (₹)</label>
                        <input type="number" id="price" name="price" class="form-control" value="<%= prodectDetails.price %>" required>

                        <label for="category">Category</label>
                        <input type="text" id="category" name="category" class="form-control" value="<%= prodectDetails.category %>" required>
                        

                        <label for="image">Change Image (Optional)</label>
                        <input type="file" id="image" name="image" class="form-control">

                        <button type="submit" class="btn-update mt-3">Save Changes</button>
                    </div>

                    <!-- Image Preview -->
                    <div class="col-md-5 mt-4 mt-md-0">
                        <label>Current Product Image</label>
                        <div class="current-image-box">
                            <% if (file != '') { %>
                                <img src="/image/<%= file %>" alt="Current Image">
                                <p class="text-muted small mt-2 mb-0">Existing Photo</p>
                            <% } else { %>
                                <div class="py-5 text-muted">No Image Available</div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

</body>

</html>