<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>I CLOUDS | Admin Portal</title>
    <!-- Sophisticated Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg-deep: #000000;
            --bg-input: #111111;
            --sage-accent: #B8C0A0; /* The muted green from the image */
            --text-dim: #888888;
            --border-color: #222222;
        }

        * {
            margin: 0; padding: 0; box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background-color: #7D8271; /* Muted olive background to frame the card */
            padding: 20px;
        }

        /* MAIN SPLIT CONTAINER */
        .main-card {
            background: var(--bg-deep);
            width: 100%;
            max-width: 1000px;
            height: 650px;
            display: flex;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 40px 100px rgba(0,0,0,0.5);
        }

        /* LEFT SIDE: ARCHITECTURAL IMAGE */
        .visual-side {
            flex: 1;
            background: url("/image/mainapple.jpg") center/cover no-repeat;
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            padding: 50px;
        }

        .visual-side::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.8) 10%, transparent 60%);
        }

        .visual-text {
            position: relative;
            color: white;
            z-index: 2;
        }

        .visual-text h1 {
            font-size: 24px;
            font-weight: 500;
            margin-bottom: 10px;
            letter-spacing: -0.5px;
        }

        .visual-text p {
            font-size: 14px;
            color: #cccccc;
            line-height: 1.6;
            max-width: 300px;
        }

        /* RIGHT SIDE: LOGIN FORM */
        .form-side {
            flex: 1;
            padding: 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .form-side h2 {
            color: white;
            font-size: 28px;
            font-weight: 500;
            margin-bottom: 12px;
        }

        .form-side .subtitle {
            color: var(--text-dim);
            font-size: 14px;
            margin-bottom: 35px;
        }

        .input-label {
            display: block;
            color: #eeeeee;
            font-size: 12px;
            margin-bottom: 8px;
            font-weight: 500;
        }

        .field-wrap {
            margin-bottom: 20px;
        }

        input, select {
            width: 100%;
            padding: 14px 16px;
            background: var(--bg-input);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            color: white;
            font-size: 14px;
            transition: 0.3s;
        }

        input:focus, select:focus {
            outline: none;
            border-color: var(--sage-accent);
        }

        /* SAGE GREEN BUTTON */
        button {
            width: 100%;
            padding: 16px;
            background: var(--sage-accent);
            border: none;
            border-radius: 8px;
            color: #2D331D; /* Deep olive text for contrast */
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            margin-top: 10px;
            transition: 0.3s;
        }

        button:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

        .back-link {
            text-align: center;
            margin-top: 25px;
            color: var(--text-dim);
            text-decoration: none;
            font-size: 13px;
            display: block;
        }

        .back-link:hover { color: white; }

        /* RESPONSIVE */
        @media (max-width: 850px) {
            .visual-side { display: none; }
            .main-card { max-width: 450px; height: auto; }
            .form-side { padding: 40px; }
        }
    </style>
</head>
<body>

<div class="main-card">
    
    <!-- Left Section -->
    <div class="visual-side">
        <div class="visual-text">
            <h1>Design your future, <br>one cloud at a time.</h1>
            <p>Join our premium network of administrators managing excellence.</p>
        </div>
    </div>

    <!-- Right Section -->
    <div class="form-side">
        <h2>Admin Access</h2>
        <p class="subtitle">Enter your credentials to manage the I Clouds store.</p>

        <form action="/admin/login" method="POST">
            
            <div class="field-wrap">
                <label class="input-label">Access Role</label>
                <select name="role">
                    <option value="admin">Administrator</option>
                </select>
            </div>

            <div class="field-wrap">
                <label class="input-label">System ID</label>
                <input type="text" name="id" placeholder="Enter ID" required>
            </div>

            <div class="field-wrap">
                <label class="input-label">Username</label>
                <input type="text" name="username" placeholder="eg. admin_user" required>
            </div>

            <div class="field-wrap">
                <label class="input-label">Password</label>
                <input type="password" name="password" placeholder="••••••••" required>
            </div>

            <button type="submit">Sign in</button>
        </form>

        <a href="/index" class="back-link">Return to Store</a>
    </div>

</div>

</body>
</html>