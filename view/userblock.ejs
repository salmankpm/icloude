<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>I Clouds | Users Management</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        :root {
            --primary-red: #ff4d4d;
            --text-dark: #222;
            --text-muted: #888;
            --bg-light: #f9f9f9;
            --border-color: #ebebeb;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: #fff;
            color: var(--text-dark);
        }

        /* TOP NAVIGATION */
        .top-nav {
            border-bottom: 1px solid var(--border-color);
            padding: 15px 0;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 24px;
            letter-spacing: 1px;
        }

        .nav-link {
            font-size: 14px;
            font-weight: 500;
            color: var(--text-dark) !important;
            margin: 0 10px;
        }
        .nav-link.active {
        font-weight: 700 !important;
        color: #000 !important;
        border-bottom: 2px solid #ff4d4d; /* Matches your red theme accent */
    }

        /* BREADCRUMB */
        .breadcrumb-section {
            background: var(--bg-light);
            padding: 20px 0;
            margin-bottom: 40px;
            font-size: 13px;
            color: var(--text-muted);
        }

        /* TABLE STYLING */
        .table-container {
            border: 1px solid var(--border-color);
            border-radius: 8px;
            overflow: hidden;
            background: white;
            padding: 20px;
        }

        .table thead {
            background-color: var(--bg-light);
        }

        .table thead th {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
            border-bottom: none;
            padding: 15px;
        }

        .table tbody td {
            font-size: 14px;
            padding: 15px;
            vertical-align: middle;
            color: var(--text-dark);
            border-color: var(--border-color);
        }

        /* BADGES */
        .badge {
            font-weight: 500;
            padding: 6px 12px;
            border-radius: 4px;
        }

        .bg-success-subtle {
            background-color: #e8f5e9 !important;
            color: #2e7d32 !important;
        }

        .bg-danger-subtle {
            background-color: #ffebee !important;
            color: #c62828 !important;
        }

        /* BUTTONS */
        .btn-action {
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 6px 16px;
            border-radius: 4px;
            transition: 0.3s;
        }

        .btn-block {
            border: 1px solid var(--primary-red);
            color: var(--primary-red);
            background: transparent;
        }

        .btn-block:hover {
            background: var(--primary-red);
            color: white;
        }

        .btn-unblock {
            border: 1px solid #2e7d32;
            color: #2e7d32;
            background: transparent;
        }

        .btn-unblock:hover {
            background: #2e7d32;
            color: white;
        }
    </style>
</head>

<body>

    <!-- TOP NAVIGATION -->
    <nav class="navbar navbar-expand-lg top-nav">
        <div class="container">
            <a class="navbar-brand text-black" href="/index">I CLOUDS</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link" href="/dashboard">Dashboard</a></li>
                  
                    <li class="nav-item"><a class="nav-link active" href="/admin/users">Users</a></li>
                    <li class="nav-item"><a class="nav-link" href="/restoreProdect">Archives</a></li>
                </ul>
                <div class="d-flex align-items-center">
                    <a href="/logoutuser" class="btn btn-outline-dark btn-sm rounded-pill px-4 mt-2 mt-lg-0">Logout</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- BREADCRUMB -->
    <div class="breadcrumb-section">
        <div class="container">
            <span>Home / Admin / User Management</span>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="container mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold m-0">Customer Accounts</h3>
            <span class="text-muted small">Total Users: <%= users.length %></span>
        </div>

        <div class="table-container shadow-sm">
            <div class="table-responsive">
                <table class="table align-middle m-0">
                    <thead>
                        <tr>
                            <th># ID</th>
                            <th>Customer Name</th>
                            <th>Password (Hash)</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach((user, index) => { %>
                            <tr>
                                <td class="text-muted">#<%= index + 1 %></td>
                                <td>
                                    <div class="fw-600"><%= user.username %></div>
                                </td>
                                <td class="text-muted small">
                                    <%= user.password.substring(0, 10) %>...
                                </td>
                                <td>
                                    <% if(user.isBlocked){ %>
                                        <span class="badge bg-danger-subtle">Suspended</span>
                                    <% } else { %>
                                        <span class="badge bg-success-subtle">Active</span>
                                    <% } %>
                                </td>
                                <td class="text-end">
                                    <% if(user.isBlocked){ %>
                                        <a href="/admin/unblock-user?userId=<%= user._id %>" 
                                           class="btn btn-action btn-unblock">
                                           Unblock Account
                                        </a>
                                    <% } else { %>
                                        <a href="/admin/block-user?userId=<%= user._id %>" 
                                           class="btn btn-action btn-block">
                                           Block Account
                                        </a>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</body>

</html>